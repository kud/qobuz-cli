{
  "name": "@kud/qobuz-cli",
  "version": "0.2.0",
  "description": "Command-line interface for Qobuz — search, library, and quick-open in the app",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kud/qobuz-cli.git"
  },
  "bin": {
    "qobuz": "./dist/index.js"
  },
  "files": [
    "dist",
    "native/media-key.swift"
  ],
  "scripts": {
    "build": "npm run build:native && tsup",
    "build:native": "swiftc -O native/media-key.swift -o native/media-key",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@kud/qobuz": "0.4.0",
    "citty": "0.2.2"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
