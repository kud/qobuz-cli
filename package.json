{
  "name": "@kud/qobuz-cli",
  "version": "0.7.0",
  "description": "Command-line interface for Qobuz — search, library, and quick-open in the app",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kud/qobuz-cli.git"
  },
  "bin": {
    "qobuz": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@kud/qobuz": "0.5.5",
    "citty": "0.2.2",
    "ink": "7.1.0",
    "ink-text-input": "6.0.0",
    "react": "19.2.7"
  },
  "optionalDependencies": {
    "@kud/macos-media-keys": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
